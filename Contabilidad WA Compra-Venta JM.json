    {
      "parameters": {
        "jsCode": "// 1. Obtenemos la salida del Agente y limpiamos posibles bloques de código Markdown\nconst raw = $node[\"AI Agent\"].json.output.replace(/```json|```/g, \"\").trim();\n\nlet data;\ntry {\n  // 2. Intentamos convertir el texto en un objeto JSON real\n  data = JSON.parse(raw);\n} catch (e) {\n  // Si la IA devuelve algo que no es JSON, generamos un error controlado\n  data = { \n    Tipo: \"Error\", \n    Concepto: \"Error de lectura IA\", \n    Monto: 0, \n    Plataforma: \"Vinted\" \n  };\n}\n\n// 3. Limpieza extra del Monto (por si viene con comas en lugar de puntos)\nlet montoNumerico = 0;\nif (data.Monto) {\n  montoNumerico = parseFloat(String(data.Monto).replace(',', '.'));\n}\n\n// 4. Devolvemos el resultado listo para Google Sheets\nreturn {\n  json: {\n    // Usamos el formato YYYY-MM-DD para que el nodo de lectura posterior no de \"undefined\"\n    Fecha: new Date().toISOString().split('T')[0], \n    Tipo: data.Tipo || \"Desconocido\",\n    Concepto: data.Concepto || \"Sin descripción\",\n    Monto: isNaN(montoNumerico) ? 0 : montoNumerico,\n    Plataforma: data.Plataforma || \"Vinted\"\n  }\n};"
      },
