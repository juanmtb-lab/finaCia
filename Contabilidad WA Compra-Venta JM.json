    {
      "parameters": {
        "jsCode": "const filas = $input.all();\nconst sumatorio = {};\n\nfilas.forEach(f => {\n  const d = f.json;\n  if (!d.Fecha || !d.Monto || d.Tipo === \"Desconocido\") return;\n\n  let mesAnio = \"\";\n  \n  // PARSEADOR BLINDADO DE FECHAS\n  const fechaStr = String(d.Fecha);\n  if (fechaStr.includes('-')) {\n    // Caso: 2026-03-21\n    const partes = fechaStr.split('-');\n    mesAnio = `${partes[1]}/${partes[0]}`; \n  } else if (fechaStr.includes('/')) {\n    // Caso: 21/03/2026\n    const partes = fechaStr.split('/');\n    // Detectamos si el año está al final (3 piezas)\n    mesAnio = partes[2] && partes[2].length === 4 ? `${partes[1]}/${partes[2]}` : `${partes[1]}/${partes[0]}`;\n  }\n\n  const plat = d.Plataforma || \"Vinted\";\n  const idUnico = `${mesAnio}-${plat}`;\n\n  if (!sumatorio[idUnico]) {\n    sumatorio[idUnico] = { ID: idUnico, Mes: mesAnio, Plataforma: plat, Total_Ventas: 0, Total_Gastos: 0, Beneficio_Neto: 0 };\n  }\n\n  const valor = parseFloat(String(d.Monto).replace(',', '.')) || 0;\n\n  if (d.Tipo === \"Venta\" || d.Tipo === \"Devolución_Favor\") {\n    sumatorio[idUnico].Total_Ventas += valor;\n  } else if (d.Tipo === \"Compra\" || d.Tipo === \"Publicidad\" || d.Tipo === \"Devolución_Contra\" || d.Tipo === \"Envío\") {\n    sumatorio[idUnico].Total_Gastos += valor;\n  }\n\n  sumatorio[idUnico].Beneficio_Neto = sumatorio[idUnico].Total_Ventas - sumatorio[idUnico].Total_Gastos;\n});\n\nreturn Object.values(sumatorio).map(resumen => ({ json: resumen }));"
      },
