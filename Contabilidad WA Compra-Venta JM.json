    {
      "parameters": {
        "jsCode": "// 1. Obtenemos todos los datos que vienen del Merge\nconst items = $input.all();\n\nlet totalVentas = 0;\nlet totalCompras = 0;\nlet totalPublicidad = 0;\nlet totalDevoFavor = 0;\nlet totalDevoContra = 0;\nlet totalEnvios = 0;\nlet valorBalanceRaw = null;\n\n// 2. Procesamos TODO en un solo bucle\nfor (let item of items) {\n  const data = item.json;\n  const tipo = String(data[\"Tipo\"] || \"\");\n\n  // Contadores exactos según las nuevas categorías\n  if (tipo === \"Venta\") totalVentas++;\n  if (tipo === \"Compra\") totalCompras++;\n  if (tipo === \"Publicidad\") totalPublicidad++;\n  if (tipo === \"Devolución_Favor\") totalDevoFavor++;\n  if (tipo === \"Devolución_Contra\") totalDevoContra++;\n  if (tipo === \"Envío\") totalEnvios++;\n\n  // 3. Buscamos el Balance Neto Total\n  for (let key in data) {\n    if (key.trim() === \"Beneficio Neto Total\" && valorBalanceRaw === null) {\n      valorBalanceRaw = data[key];\n    }\n  }\n}\n\n// 4. Formateo profesional de la moneda\nlet beneficioFinal = \"0,00 €\";\nif (valorBalanceRaw !== null) {\n  beneficioFinal = Number(valorBalanceRaw).toLocaleString('es-ES', { \n    style: 'currency', \n    currency: 'EUR' \n  });\n}\n\n// 5. Construcción del mensaje con las nuevas categorías\nconst mensajeFinal = `📊 *RESUMEN DE ACTIVIDAD*\n--------------------------\n💰 *Ventas:* ${totalVentas}\n🛒 *Compras:* ${totalCompras}\n📢 *Publicidad:* ${totalPublicidad}\n\n🔄 *DEVOLUCIONES:*\n✅ *A favor (recuperado):* ${totalDevoFavor}\n❌ *En contra (devuelto):* ${totalDevoContra}\n\n🚚 *ENVÍOS:*\n📦 *Gastos de envío:* ${totalEnvios}\n\n━━━━━━━━━━━━━━━━━━\n💵 *BALANCE NETO TOTAL:*\n👉 *${beneficioFinal}*\n━━━━━━━━━━━━━━━━━━\n\n✅ Registro completado con éxito.`;\n\nreturn [\n  {\n    json: {\n      mensaje_whatsapp: mensajeFinal,\n      datos: {\n        ventas: totalVentas,\n        compras: totalCompras,\n        publicidad: totalPublicidad,\n        devoluciones_favor: totalDevoFavor,\n        devoluciones_contra: totalDevoContra,\n        envios: totalEnvios,\n        balance: beneficioFinal\n      }\n    }\n  }\n];"
      },
